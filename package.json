{
  "name": "marketing-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@3.6.4",
  "workspaces": [
    "web",
    "api/packages/*",
    "api/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "lint": "yarn workspaces foreach -At run lint",
    "test": "yarn workspaces foreach -At run test",
    "type-check": "yarn workspaces foreach -At run type-check",
    "dev:web": "yarn workspace @marketing/web dev",
    "dev:core": "yarn workspace @marketing/marketing-core dev"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "eslint": "8.57.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=3.0.0"
  }
}
