# API base URL — same-origin path. Vite proxies /api → individual services in dev,
# Nginx upstream does the routing in production.
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=Marketing Platform

# Vite dev server port
VITE_DEV_PORT=3000

# ─────────────────────────────────────────────────────────────────────
# Dev-only proxy targets — override per-service when the API lives off-box.
# In production these are ignored (Nginx handles the routing).
# Leave commented to use the localhost defaults baked into vite.config.ts.
# ─────────────────────────────────────────────────────────────────────
# VITE_PROXY_CORE=http://localhost:3100
# VITE_PROXY_SEO=http://localhost:3101
# VITE_PROXY_CONTENT=http://localhost:3102
# VITE_PROXY_CAMPAIGN=http://localhost:3103
# VITE_PROXY_ANALYTICS=http://localhost:3104
# VITE_PROXY_SOCIAL=http://localhost:3105
# VITE_PROXY_EMAIL=http://localhost:3106
# VITE_PROXY_INTELLIGENCE=http://localhost:3107
# VITE_PROXY_AFFILIATE=http://localhost:3108
# VITE_PROXY_INFLUENCER=http://localhost:3109
# VITE_PROXY_CRM=http://localhost:3110
# VITE_PROXY_MEDIA=http://localhost:3111
# VITE_PROXY_NOTIFICATION=http://localhost:3112
# VITE_PROXY_INTEGRATION=http://localhost:3113

# Public URL where the UTM click-tracking redirect (/u/:short_code) is served from.
# Default (unset) means same-origin: `${window.location.origin}/api/v1/campaign`.
# For production, set to your tracking subdomain, e.g. https://go.yourdomain.com
# VITE_UTM_REDIRECT_BASE=https://go.yourdomain.com

# Public URL where the affiliate tracking-link redirect lives (/a/:code).
# Default (unset) means same-origin: `${window.location.origin}/api/v1/affiliate`.
# VITE_AFFILIATE_REDIRECT_BASE=https://refer.yourdomain.com
