# ─── Service Identity ─────────────────────────────────────────────────
SERVICE_NAME=marketing-core
NODE_ENV=development
PORT=3100

# ─── Database (remote MySQL) ──────────────────────────────────────────
DB_NAME=digitalmarketing
DB_USER=amgprojects
DB_PASS=Amigo@25!
DB_HOST=68.178.239.242
DB_PORT=3306
DB_DIALECT=mysql
# Sequelize uses DATABASE_URL preferentially; built from the parts above by env.ts
# (You can also set it directly to override.)
# DATABASE_URL=mysql://amgprojects:Amigo@25!@68.178.239.242:3306/digitalmarketing
DB_POOL_MAX=10
DB_POOL_MIN=2
# DANGER: setting RESET_DB=true will DROP every core_* table on next boot
RESET_DB=false

# ─── Redis (local) ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=digi:

# ─── Auth (CHANGE FOR PRODUCTION — must be 32+ random bytes) ──────────
JWT_SECRET=dev-secret-please-change-me-in-production-min-32-chars
JWT_ACCESS_TOKEN_LIFETIME=15m
JWT_REFRESH_TOKEN_LIFETIME=30d

# ─── Encryption (CHANGE FOR PRODUCTION — 32-byte hex) ─────────────────
MASTER_DEK_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Storage (local for dev; swap to s3 for production) ───────────────
STORAGE_DRIVER=local
STORAGE_PUBLIC_URL_BASE=http://localhost:3100
LOCAL_STORAGE_PATH=./.local-storage
LOCAL_STORAGE_PUBLIC_PATH_PREFIX=/files

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── CORS (frontend dev origins) ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
APP_BASE_URL=http://localhost:3000

# ─── Email (SendGrid) ─────────────────────────────────────────────────
EMAIL_DRIVER=stub
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourplatform.local
EMAIL_FROM_NAME=Marketing Platform

# ─── Stripe ───────────────────────────────────────────────────────────
STRIPE_DRIVER=stub
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ─── Observability ────────────────────────────────────────────────────
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
