# ─── Service Identity ─────────────────────────────────────────────────
SERVICE_NAME=social-hub
NODE_ENV=development
PORT=3105

# ─── Database (remote MySQL — same DB used by all services) ───────────
DB_NAME=digitalmarketing
DB_USER=amgprojects
DB_PASS=Amigo@25!
DB_HOST=68.178.239.242
DB_PORT=3306
DB_DIALECT=mysql
DB_POOL_MAX=10
DB_POOL_MIN=2

# ─── Redis (local) ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=digi:

# ─── Auth (CHANGE FOR PRODUCTION — must match across all services) ────
JWT_SECRET=dev-secret-please-change-me-in-production-min-32-chars
MASTER_DEK_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Storage ──────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PUBLIC_URL_BASE=http://localhost:3105
LOCAL_STORAGE_PATH=./.local-storage
LOCAL_STORAGE_PUBLIC_PATH_PREFIX=/files

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=debug

SOCIAL_DRIVER=stub
META_APP_ID=
META_APP_SECRET=
